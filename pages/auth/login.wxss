.login-page {
  min-height: 100vh;
  padding: 56rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background:
    radial-gradient(circle at right top, rgba(71, 113, 155, 0.18), transparent 30%),
    linear-gradient(180deg, #f8fbff 0%, #f4f7fb 45%, #f4f7fb 100%);
}

.login-hero {
  margin-bottom: 28rpx;
  padding: 44rpx 36rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #2d597b 0%, #376e9d 58%, #4b88b9 100%);
  color: #fff;
  box-shadow: 0 18rpx 42rpx rgba(28, 56, 84, 0.16);
}

.hero-title {
  font-size: 54rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.9);
}

.login-container {
  width: 100%;
}

.login-card {
  padding: 40rpx 32rpx;
}

.login-title {
  font-size: 42rpx;
  font-weight: 700;
  text-align: center;
  color: var(--text-primary);
}

.login-subtitle {
  margin-top: 12rpx;
  margin-bottom: 32rpx;
  text-align: center;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.tabs {
  display: flex;
  padding: 8rpx;
  background: #eef3f8;
  border-radius: 999rpx;
  margin-bottom: 32rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  color: var(--text-secondary);
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.tab-item.active {
  color: #fff;
  background: linear-gradient(135deg, #47719b 0%, #2d597b 100%);
  box-shadow: 0 10rpx 24rpx rgba(45, 89, 123, 0.18);
}

.login-form {
  display: flex;
  flex-direction: column;
}

.form-group {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.code-input {
  flex: 1;
}

.code-btn {
  min-width: 184rpx;
  padding: 0 20rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-color);
  background: var(--primary-soft);
  border: 2rpx solid #d7e3ef;
}

.code-btn.disabled {
  color: var(--text-tertiary);
  background: #f0f3f7;
  border-color: #e2e8f0;
}

.form-footer {
  display: flex;
  justify-content: flex-end;
  margin: 8rpx 0 28rpx;
}

.link {
  color: var(--primary-color);
  font-size: 26rpx;
  font-weight: 600;
}

.login-btn {
  margin-top: 8rpx;
}
